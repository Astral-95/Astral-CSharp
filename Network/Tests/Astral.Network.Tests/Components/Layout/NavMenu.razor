@code {
	protected override void OnInitialized()
	{
		Theme.OnChanged += StateHasChanged;
	}

	private bool IsDark;

	private void OnToggle()
	{
		IsDark = !IsDark;
		Theme.Toggle(); // assumes this exists in your project (you already used it)
	}
}